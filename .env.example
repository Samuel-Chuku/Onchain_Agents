# ── Wallets ──────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=0x...          # EVM wallet private key (0x-prefixed)
SOLANA_PRIVATE_KEY=...            # Solana wallet private key (base58-encoded)

# ── API Keys ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=...            # https://openrouter.ai
UNISWAP_API_KEY=...               # https://hub.uniswap.org

# ── EVM RPC URLs ─────────────────────────────────────────────────────────────
# Public endpoints work for testing. Use Alchemy/Infura for production.
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
ETH_MAINNET_RPC_URL=https://cloudflare-eth.com
MONAD_RPC_URL=https://rpc.monad.xyz
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Testnets (only needed if using index.ts)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ETH_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Helius recommended for low latency. Register at https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=...
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=...

# Note: Ethereum mainnet swaps use Flashbots Protect RPC automatically
# (https://rpc.flashbots.net) — no key required, no extra config needed.
